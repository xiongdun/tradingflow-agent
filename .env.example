# ============================================================
# TradingFlow Agent - 配置文件
# 复制为 .env 并填写你的信息
# 使用方式: cp .env.example .env  → 编辑 .env → 启动
# ============================================================

# ============================================================
# 🔑 LLM 大模型配置（必填！这是核心配置，没有它分析无法运行）
# ============================================================

# 模型提供商，支持: deepseek(推荐), openai, qwen, mimo(xiaomi), claude, ollama
# deepseek — 性价比最高，注册即用 https://platform.deepseek.com
# openai — GPT系列，需绑定信用卡   https://platform.openai.com
# qwen — 阿里通义千问             https://dashscope.aliyun.com
# mimo — 小米大模型
# claude — Anthropic Claude
# ollama — 本地运行，不需要联网和API Key
LLM_PROVIDER=deepseek

# 模型名称
# deepseek → deepseek-chat（便宜）或 deepseek-reasoner（深度思考）
# openai → gpt-4o / gpt-4o-mini
# qwen → qwen-plus / qwen-max
LLM_MODEL=deepseek-chat

# API 密钥（从对应平台获取，https://platform.deepseek.com/api_keys）
LLM_API_KEY=your-api-key-here

# API 地址（通常不需要改，Ollama本地运行时改为 http://localhost:11434/v1）
LLM_BASE_URL=https://api.deepseek.com/v1

# 温度参数 0~1，越低越严谨，越高越有创造性
LLM_TEMPERATURE=0.3

# 最大输出 Token 数
LLM_MAX_TOKENS=4096

# ============================================================
# 📊 数据源（无需配置，AKShare 和 yfinance 免费免 Key）
# 数据源链式自动降级：AKShare → yfinance → efinance → baostock
# 一个挂了会自动切到下一个，不用担心数据中断
# ============================================================

# ============================================================
# ⚙️ 分析参数
# ============================================================

# 默认市场: a_share(A股), h_stock(港股), us_stock(美股)
DEFAULT_MARKET=a_share

# 分析超时时间（秒），复杂分析可能需要更长时间
ANALYSIS_TIMEOUT=120

# ============================================================
# 🌐 服务器配置
# ============================================================

# API 服务地址，0.0.0.0 表示本机所有网络接口都可访问
API_HOST=0.0.0.0

# API 服务端口，默认 8000，冲突时可改为 8001/8080 等
API_PORT=8000

# ============================================================
# 📝 日志
# ============================================================

# 日志级别: DEBUG(调试), INFO(信息), WARNING(警告), ERROR(错误)
LOG_LEVEL=INFO

# ============================================================
# 🎨 显示设置
# ============================================================

# K线颜色方案:
# cn — 红涨绿跌（中国市场习惯，中国红=上涨吉祥）
# international — 绿涨红跌（国际市场习惯）
COLOR_SCHEME=cn

# 界面语言: zh(中文), en(English)
LANGUAGE=zh