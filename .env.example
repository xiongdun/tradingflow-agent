# ============================================================
# Vibe Trading Agent - Configuration
# Copy to .env and fill in your values
# ============================================================

# --- LLM Configuration ---
# Supported providers: openai, deepseek, qwen, xiaomi/mimo, claude, ollama
LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-chat
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=4096

# --- Data Sources ---
# AKShare is free and requires no API key
# yfinance is free and requires no API key

# --- Analysis Settings ---
# Default market: a_share, h_stock, us_stock
DEFAULT_MARKET=a_share
ANALYSIS_TIMEOUT=120

# --- Server Configuration ---
API_HOST=0.0.0.0
API_PORT=8000

# --- Logging ---
LOG_LEVEL=INFO

# --- Display Settings ---
# Color scheme for stock price changes:
# cn = Red up, Green down (Chinese market convention)
# international = Green up, Red down (International market convention)
COLOR_SCHEME=cn

# Language: zh = Chinese, en = English
LANGUAGE=zh
